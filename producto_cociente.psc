Algoritmo producto_cociente
	Definir a,b Como Real
	
	Escribir "Ingrese el primer numero:"
	Leer a
	
	Escribir "Ingrese el segundo numero:"
	Leer b
	
	Escribir "Producto: ", a * b
	
	Si b <> 0 Entonces
		Escribir "Cociente: ", a / b
	SiNo
		Escribir "No se puede dividir entre cero"
	FinSi
FinAlgoritmo
